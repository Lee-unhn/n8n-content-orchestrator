# ============================================================
# n8n Content Orchestrator — environment template (v3)
# ============================================================
# Copy to .env and fill in. Never commit the real .env.
# All secrets injected into the n8n container via docker-compose.

# ===== GitHub Gist (cloud-to-cloud bridge) =====
# Generate at https://github.com/settings/tokens (classic)
# Minimum scope: gist
GIST_PAT=ghp_xxx_REPLACE_WITH_YOUR_GIST_PAT

# ===== Facebook Page (system user permanent token) =====
# Path: business.facebook.com -> System Users -> Generate token
# Permissions: pages_show_list, pages_read_engagement, pages_manage_posts,
#              pages_manage_metadata, business_management,
#              instagram_basic, instagram_content_publish
FB_SYSTEM_USER_TOKEN=EAA_xxx_REPLACE_WITH_YOUR_SYSTEM_USER_TOKEN
FB_PAGE_ID=000000000000000
FB_GRAPH_VERSION=v24.0

# ===== Instagram Business (linked to FB Page, uses same system user token) =====
# Get with: curl "graph.facebook.com/v24.0/{FB_PAGE_ID}?fields=instagram_business_account&access_token={TOKEN}"
IG_BUSINESS_ACCOUNT_ID=000000000000000

# ===== Threads (separate OAuth flow, 60-day expiry, must refresh) =====
# Path: developers.facebook.com -> your App -> Threads -> User token generator
THREADS_USER_ID=
THREADS_LONG_LIVED_TOKEN=
THREADS_APP_ID=
THREADS_APP_SECRET=

# ===== Meta App (FB / IG main App) =====
META_APP_ID=
META_APP_SECRET=

# ===== Google Drive (separate API key, restricted to Drive API only) =====
# Drive API enable: console.cloud.google.com/apis/library/drive.googleapis.com
# Cannot share key with Gemini API; build a separate Drive-only key
DRIVE_API_KEY=
DRIVE_INBOX_FOLDER_ID=

# ===== Pollinations.ai (no key needed, free fallback image gen) =====
# This system is hard-coded. No env var required.

# ===== ImgBB (anonymous image upload to host public URL for IG) =====
# Get at https://api.imgbb.com -> Get API key
# Variable named IMGUR_CLIENT_ID for legacy (was originally Imgur, switched to ImgBB)
IMGUR_CLIENT_ID=

# ===== Gemini (legacy slot, currently unused after Pollinations.ai pivot) =====
# Imagen requires paid plan; keep slot in case future use
GEMINI_API_KEY=
