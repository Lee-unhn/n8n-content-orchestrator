# ============================================================
# n8n Content Orchestrator — environment template
# ============================================================
# Copy to .env and fill in. Never commit the real .env.

# ---- GitHub Gist (cloud-to-cloud bridge) ----
# Create at https://github.com/settings/tokens (classic).
# Minimum scope required: gist
# No expiration recommended for unattended automation.
GIST_PAT=ghp_xxx_REPLACE_WITH_YOUR_GIST_PAT

# ---- Facebook Graph API ----
# 1) Create a Meta Business Portfolio + System User (Admin role on the Page)
# 2) Generate System User permanent token with permissions:
#    pages_show_list, pages_read_engagement, pages_manage_posts
# 3) The system user token is what goes here (not the user token).
#    The workflow exchanges it to a page-scoped token at runtime via /me/accounts.
FB_SYSTEM_USER_TOKEN=EAA_xxx_REPLACE_WITH_YOUR_SYSTEM_USER_TOKEN
FB_PAGE_ID=000000000000000
FB_GRAPH_VERSION=v24.0
